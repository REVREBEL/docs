{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "RERBEL Library",
  "colors": {
    "primary": "#163666",
    "light": "#eff5f6",
    "dark": "#163666"
  },
  "favicon": {
    "light": "/favicon-light.svg",
    "dark": "/favicon-dark.svg"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://mintlify.com/docs",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Blog",
          "href": "https://rerebel.io/blog",
          "icon": "newspaper"
        }
      ]
    },
    "products": [
      {
        "product": "Metrics",
        "tabs": [
          {
            "tab": "Guides",
            "groups": [
              {
                "group": "Getting started",
                "pages": [
                  "index",
                  "quickstart",
                  "development"
                ]
              },
              {
                "group": "Customization",
                "pages": [
                  "essentials/settings",
                  "essentials/navigation"
                ]
              },
              {
                "group": "Writing content",
                "pages": [
                  "essentials/markdown",
                  "essentials/code",
                  "essentials/images",
                  "essentials/components",
                  "essentials/reusable-snippets"
                ]
              },
              {
                "group": "Agent ready",
                "pages": [
                  "agent-ready/prompt",
                  "agent-ready/visibility",
                  "agent-ready/contextual",
                  "ai-tools/cursor",
                  "ai-tools/claude-code",
                  "ai-tools/windsurf"
                ]
              }
            ]
          },
          {
            "tab": "API reference",
            "groups": [
              {
                "group": "API documentation",
                "pages": [
                  "api-reference/introduction"
                ]
              },
              {
                "group": "Endpoint examples",
                "pages": [
                  "api-reference/endpoint/get",
                  "api-reference/endpoint/create",
                  "api-reference/endpoint/delete",
                  "api-reference/endpoint/webhook"
                ]
              }
            ]
          },
          {
            "tab": "Metrics Library",
            "groups": [
              {
                "group": "Overview",
                "pages": [
                  "metrics-library/index.mdx"
                ]
              },
              {
                "group": "Standards",
                "pages": [
                  "metrics-library/column-naming-standards.mdx",
                  "metrics-library/table-prefix-standards.mdx",
                  "metrics-library/table-architecture.mdx"
                ]
              },
              {
                "group": "Table Models",
                "pages": [
                  "metrics-library/costar-processing-spec.mdx",
                  "metrics-library/costar-processing-guide.mdx",
                  "metrics-library/forecast-budget-pricing.mdx",
                  "metrics-library/events-table-model.mdx",
                  "metrics-library/demand-table-models.mdx",
                  "metrics-library/source-file-ingestion.mdx"
                ]
              },
              {
                "group": "Dimensional Models",
                "pages": [
                  "metrics-library/roomtype-model.mdx",
                  "metrics-library/segment-model.mdx",
                  "metrics-library/source-channel-rate-model.mdx"
                ]
              },
              {
                "group": "Audits",
                "pages": [
                  "metrics-library/column-propagation-audit.mdx"
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Helpdesk",
        "href": "mailto:helpdesk@revrebel.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/revrebel",
      "linkedin": "https://linkedin.com/company/revrebel"
    }
  },
  "background": {
    "color": {
      "light": "#eff5f6",
      "dark": "#163666"
    }
  },
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "family": "Roboto",
    "weight": 300,
    "source": "https://fonts.googleapis.com/css2?family=Fira+Code:wght@300..700&family=Khand:wght@300;400;500;600;700&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap",
    "format": "woff2"
  }
}
