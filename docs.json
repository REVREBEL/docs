{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "REVREBEL Library",
  "description": "REVREBEL's source of truth for hospitality metrics, table models, naming standards, and data architecture.",
  "colors": {
    "primary": "#163666",
    "light": "#fafafa",
    "dark": "#163666"
  },
  "favicon": {
    "light": "/favicon-light.svg",
    "dark": "/favicon-dark.svg"
  },
  "logo": {
    "light": "/logo/dark.svg",
    "dark": "/logo/light.svg"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://mintlify.com/docs",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Blog",
          "href": "https://revrebel.io/blog",
          "icon": "newspaper"
        }
      ]
    },
    "products": [
      {
        "product": "Metrics",
        "tabs": [
          {
            "tab": "Guides",
            "groups": [
              {
                "group": "Getting started",
                "pages": [
                  "index",
                  "quickstart",
                  "development"
                ]
              },
              {
                "group": "Customization",
                "pages": [
                  "essentials/settings",
                  "essentials/navigation"
                ]
              },
              {
                "group": "Writing content",
                "pages": [
                  "essentials/markdown",
                  "essentials/code",
                  "essentials/images",
                  "essentials/components",
                  "essentials/reusable-snippets"
                ]
              },
              {
                "group": "Agent ready",
                "pages": [
                  "agent-ready/prompt",
                  "agent-ready/visibility",
                  "agent-ready/contextual",
                  "ai-tools/cursor",
                  "ai-tools/claude-code",
                  "ai-tools/windsurf"
                ]
              }
            ]
          },
          {
            "tab": "API reference",
            "groups": [
              {
                "group": "API documentation",
                "pages": [
                  "api-reference/introduction"
                ]
              },
              {
                "group": "Endpoint examples",
                "pages": [
                  "api-reference/endpoint/get",
                  "api-reference/endpoint/create",
                  "api-reference/endpoint/delete",
                  "api-reference/endpoint/webhook"
                ]
              }
            ]
          },
          {
            "tab": "Metrics Library",
            "groups": [
              {
                "group": "Overview",
                "pages": [
                  "metrics-library/index"
                ]
              },
              {
                "group": "Standards",
                "pages": [
                  "metrics-library/column-naming-standards",
                  "metrics-library/table-prefix-standards",
                  "metrics-library/table-architecture"
                ]
              },
              {
                "group": "Table Models",
                "pages": [
                  "metrics-library/costar-processing-spec",
                  "metrics-library/costar-processing-guide",
                  "metrics-library/forecast-budget-pricing",
                  "metrics-library/events-table-model",
                  "metrics-library/demand-table-models",
                  "metrics-library/source-file-ingestion"
                ]
              },
              {
                "group": "GA4 Origin Tables",
                "pages": [
                  "metrics_g4a/index",
                  "metrics_g4a/p_ga4_Events",
                  "metrics_g4a/p_ga4_Audiences",
                  "metrics_g4a/p_ga4_DemographicDetails",
                  "metrics_g4a/p_ga4_EcommercePurchases",
                  "metrics_g4a/p_ga4_LandingPage",
                  "metrics_g4a/p_ga4_PagesAndScreens",
                  "metrics_g4a/p_ga4_Promotions",
                  "metrics_g4a/p_ga4_TechDetails",
                  "metrics_g4a/p_ga4_TrafficAcquisition",
                  "metrics_g4a/p_ga4_UserAcquisition"
                ]
              },
              {
                "group": "Dimensional Models",
                "pages": [
                  "metrics-library/roomtype-model",
                  "metrics-library/segment-model",
                  "metrics-library/source-channel-rate-model"
                ]
              },
              {
                "group": "Audits",
                "pages": [
                  "metrics-library/column-propagation-audit"
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Helpdesk",
        "href": "mailto:helpdesk@revrebel.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/revrebel",
      "linkedin": "https://linkedin.com/company/revrebel"
    }
  },
  "background": {
    "color": {
      "light": "#fafafa",
      "dark": "#163666"
    }
  },
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "family": "Roboto",
    "weight": 400,
    "source": "https://fonts.googleapis.com/css2?family=Fira+Code:wght@300..700&family=Khand:wght@300;400;500;600;700&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap",
    "format": "woff2"
  }
}
